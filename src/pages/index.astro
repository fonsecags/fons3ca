---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import gustavoImg from '../assets/gustavo.png';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---

<BaseLayout title="FONS3CA">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">

        <div class="hero-left">
          <Image src={gustavoImg} alt="Gustavo Fonseca" class="hero-avatar" width={384} height={384} format="webp" quality={90} loading="eager" fetchpriority="high" />
          <p class="eyebrow">Performance Marketing · AI · Dev</p>
          <h1>
            Building<br />
            sharper.
          </h1>
          <p class="location">Brazil · London · Malaga</p>
        </div>

        <div class="hero-right">
          <p class="hero-intro">
            I'm Gustavo. Over 20 years running performance marketing for some of the world's
            biggest brands. I care about the work that actually moves things: stronger results,
            sharper teams, cleaner strategy. I write about what I learn along the way,
            now from a beach in Málaga.
          </p>

          <div class="pillars">
            <div class="pillar">
              <span class="pillar-label">Performance</span>
              <p>What actually moves the number. Not the vanity metrics, not the pretty report. The decision that changes next month.</p>
            </div>
            <div class="pillar">
              <span class="pillar-label">AI</span>
              <p>Less noise, more signal. Where it genuinely changes outcomes and where it is just process dressed up as progress.</p>
            </div>
            <div class="pillar">
              <span class="pillar-label">Building Things</span>
              <p>What you learn when you have to make it work yourself. The part nobody writes about until after it ships.</p>
            </div>
          </div>

          <a href="/about" class="hero-cta">Read my story →</a>
        </div>

      </div>
    </div>
  </section>

  <div class="container">

    <!-- Posts -->
    {posts.length > 0 && (
      <section class="posts-section">
        <div class="section-label">
          <span>Latest writing</span>
          <hr class="label-line" />
        </div>
        <div class="posts-grid">
          {posts.map((post) => (
            <a href={`/writing/${post.id}`} class="post-card">
              <div class="post-thumb">
                <img src={post.data.image ?? `/og/${post.id}.png`} alt={post.data.title} loading="lazy" />
              </div>
              <div class="post-body">
                <time>{formatDate(post.data.date)}</time>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="read-more">Read →</span>
              </div>
            </a>
          ))}
        </div>
        {posts.length >= 6 && (
          <div class="all-link">
            <a href="/writing">All writing →</a>
          </div>
        )}
      </section>
    )}

    {posts.length === 0 && (
      <section class="empty">
        <p>Writing incoming.</p>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    border-bottom: 1px solid var(--border);
    padding: 5rem 0;
    margin-bottom: 5rem;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  /* Left */
  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .hero-avatar {
    width: 128px;
    height: 128px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center 20%;
    border: 3px solid #3a3a3a;
    outline: 1px solid #252525;
    box-shadow: 0 0 0 6px #1a1a1a;
    flex-shrink: 0;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-left h1 {
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--text);
  }

  .location {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }

  /* Right */
  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding-top: 0.25rem;
  }

  .hero-intro {
    font-size: 1.05rem;
    color: #AAAAAA;
    line-height: 1.75;
  }

  .pillars {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
  }

  .pillar {
    padding: 1.1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .pillar:last-child {
    border-bottom: none;
  }

  .pillar-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .pillar p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0;
  }

  .hero-cta {
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
    transition: color 0.15s;
    align-self: flex-start;
  }

  .hero-cta:hover {
    color: var(--text);
  }

  /* Posts */
  .posts-section {
    padding-bottom: 4rem;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .section-label span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .label-line {
    flex: 1;
    border: none;
    border-top: 1px solid var(--border);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    transition: background 0.15s;
  }

  .post-card:hover {
    background: var(--surface);
    color: inherit;
  }

  .post-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .post-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left top;
    display: block;
    transition: transform 0.3s ease;
  }

  .post-card:hover .post-thumb img {
    transform: scale(1.02);
  }

  .post-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    flex: 1;
  }

  .post-card time {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .post-card h2 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
  }

  .post-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }

  .read-more {
    font-size: 0.8rem;
    color: var(--accent);
    margin-top: 0.5rem;
  }

  .all-link {
    margin-top: 2rem;
    text-align: right;
  }

  .all-link a {
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .all-link a:hover {
    color: var(--text);
  }

  .empty {
    padding: 4rem 0;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .hero-inner {
      gap: 3rem;
    }

    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .hero {
      padding: 3rem 0;
      margin-bottom: 3rem;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero-left h1 {
      font-size: clamp(2.75rem, 12vw, 4rem);
    }

    .pillars {
      font-size: 0.9rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .posts-section {
      padding-bottom: 3rem;
    }
  }
</style>
