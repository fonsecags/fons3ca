---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogType?: string;
  ogImage?: string;
  articleDate?: Date;
}

const {
  title,
  description = 'Ideas on performance marketing, AI, and software by Gustavo Fonseca.',
  ogType = 'website',
  ogImage,
  articleDate,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title === 'FONS3CA' ? title : `${title} · FONS3CA`;
const ogImageURL = ogImage ? new URL(ogImage, Astro.site).toString() : null;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Gustavo Fonseca',
  url: 'https://fons3ca.com',
  sameAs: ['https://www.linkedin.com/in/gustavofonseca85/'],
  jobTitle: 'Performance Marketing Specialist',
  description: 'Over 20 years running performance marketing for some of the world\'s biggest brands.',
};

const articleSchema = ogType === 'article' ? {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  url: canonicalURL,
  datePublished: articleDate?.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Gustavo Fonseca',
    url: 'https://fons3ca.com',
  },
  publisher: {
    '@type': 'Person',
    name: 'Gustavo Fonseca',
    url: 'https://fons3ca.com',
  },
  ...(ogImageURL ? { image: ogImageURL } : {}),
} : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0A0A0A" />
    <meta name="author" content="Gustavo Fonseca" />
    <meta name="robots" content="index, follow" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="FONS3CA" />
    <meta property="og:locale" content="en_GB" />
    {ogImageURL && <meta property="og:image" content={ogImageURL} />}
    {ogImageURL && <meta property="og:image:width" content="1200" />}
    {ogImageURL && <meta property="og:image:height" content="630" />}
    {articleDate && <meta property="article:published_time" content={articleDate.toISOString()} />}
    {articleDate && <meta property="article:author" content="Gustavo Fonseca" />}

    <meta name="twitter:card" content={ogImageURL ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@gustavofonseca" />
    {ogImageURL && <meta name="twitter:image" content={ogImageURL} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" /></noscript>

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
